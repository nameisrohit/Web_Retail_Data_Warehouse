                  dataType="System.String"
                  description="Specifies the SQL statement used by the component to extract data."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT t.transaction_id, t.Qty, t.Rate, t.Tax, t.total_amt, t.Store_type, c.customer_Id, p.prod_cat_code, p.prod_sub_cat_code, CONVERT(VARCHAR(10), t.tran_date, 120) AS tran_date, p.prod_cat, p.prod_subcat
