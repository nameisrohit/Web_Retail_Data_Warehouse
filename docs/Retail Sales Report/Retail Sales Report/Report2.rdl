  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>Retail_Sales_Data</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>666febac-852e-48a0-8327-655a9e1e4b80</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT        Customer.customer_Id, Customer.Gender, COUNT(Transactions.transaction_id) AS Total_Transactions, SUM(Transactions.Qty) AS Total_Qty, SUM(Transactions.total_amt) AS Total_Spent
FROM            Customer INNER JOIN
                         Transactions ON Customer.customer_Id = Transactions.cust_id
GROUP BY Customer.customer_Id, Customer.Gender</CommandText>
      </Query>
      <Fields>
        <Field Name="customer_Id">
          <DataField>customer_Id</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Gender">
          <DataField>Gender</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Total_Transactions">
          <DataField>Total_Transactions</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Total_Qty">
          <DataField>Total_Qty</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Total_Spent">
          <DataField>Total_Spent</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
