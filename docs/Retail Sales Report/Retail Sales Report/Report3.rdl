  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>Retail_Sales_Data</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>697bc1bb-d822-40c4-a82a-a77d10891004</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT        prod_cat_info.prod_cat, prod_cat_info.prod_subcat, SUM(Transactions.Qty) AS Total_Qty, SUM(Transactions.total_amt) AS Total_Revenue
FROM            prod_cat_info INNER JOIN
                         Transactions ON prod_cat_info.prod_cat_code = Transactions.prod_cat_code AND prod_cat_info.prod_sub_cat_code = Transactions.prod_subcat_code
GROUP BY prod_cat_info.prod_cat, prod_cat_info.prod_subcat</CommandText>
      </Query>
      <Fields>
        <Field Name="prod_cat">
          <DataField>prod_cat</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="prod_subcat">
          <DataField>prod_subcat</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Total_Qty">
          <DataField>Total_Qty</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Total_Revenue">
          <DataField>Total_Revenue</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
