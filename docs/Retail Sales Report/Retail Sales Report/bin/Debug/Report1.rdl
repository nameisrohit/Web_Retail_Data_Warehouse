  <DataSources>
    <DataSource Name="Retail_Sales_Data">
      <DataSourceReference>Retail_Sales_Data</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>9681574e-57c7-4b79-968e-2e2eceeb9688</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Retail_Sales_Data</DataSourceName>
        <CommandText>SELECT        Dim_Store.store_type, Dim_Product.prod_cat, SUM(Fact_Transactions.Tax) AS Total_Tax
FROM            Dim_Product INNER JOIN
                         Fact_Transactions ON Dim_Product.prod_subcat_key = Fact_Transactions.prod_subcat_key INNER JOIN
                         Dim_Store ON Fact_Transactions.store_key = Dim_Store.store_key
GROUP BY Dim_Store.store_type, Dim_Product.prod_cat</CommandText>
      </Query>
      <Fields>
        <Field Name="prod_cat">
          <DataField>prod_cat</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Total_Tax">
          <DataField>Total_Tax</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="store_type">
          <DataField>store_type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
